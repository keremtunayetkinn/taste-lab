{
  "functions": {
    "api/claude.js": { "memory": 256, "maxDuration": 30 },
    "api/pexels.js": { "memory": 256, "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; img-src 'self' https://images.pexels.com data: blob:; connect-src 'self'; style-src 'self' 'unsafe-inline'; frame-ancestors 'none'" }
      ]
    }
  ]
}
